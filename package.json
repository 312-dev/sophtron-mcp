{
  "name": "sophtron-mcp",
  "version": "1.0.0",
  "description": "Sophtron MCP server for Claude Desktop — query bank accounts and transactions via Sophtron's financial data API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sophtron-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "npx tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "axios": "^1.9.0",
    "dotenv": "^17.2.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "outDir": "dist",
    "external": []
  }
}
